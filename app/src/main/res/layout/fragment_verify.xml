<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FDFE"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center_horizontal">

        <!-- Títol -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Verifica el teu número"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#476568"
            android:layout_marginBottom="8dp" />

        <!-- Informació del telèfon -->
        <TextView
            android:id="@+id/tvPhoneInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="#8BC6CC"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <!-- Inputs del codi (6 dígits) - CORREGIT -->
        <LinearLayout
            android:layout_width="398dp"
            android:layout_height="102dp"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etCode1"
                android:layout_width="42dp"
                android:layout_height="65dp"
                android:layout_margin="4dp"
                android:background="@drawable/border_highlight"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:padding="0dp"
                android:textColor="#476568"
                android:textSize="26sp" />

            <EditText
                android:id="@+id/etCode2"
                android:layout_width="42dp"
                android:layout_height="65dp"
                android:layout_margin="4dp"
                android:background="@drawable/border_highlight"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:padding="0dp"
                android:textColor="#476568"
                android:textSize="26sp" />

            <EditText
                android:id="@+id/etCode3"
                android:layout_width="42dp"
                android:layout_height="65dp"
                android:layout_margin="4dp"
                android:background="@drawable/border_highlight"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:padding="0dp"
                android:textColor="#476568"
                android:textSize="26sp" />

            <EditText
                android:id="@+id/etCode4"
                android:layout_width="42dp"
                android:layout_height="65dp"
                android:layout_margin="4dp"
                android:background="@drawable/border_highlight"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:padding="0dp"
                android:textColor="#476568"
                android:textSize="26sp" />

            <EditText
                android:id="@+id/etCode5"
                android:layout_width="42dp"
                android:layout_height="65dp"
                android:layout_margin="4dp"
                android:background="@drawable/border_highlight"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:padding="0dp"
                android:textColor="#476568"
                android:textSize="26sp" />

            <EditText
                android:id="@+id/etCode6"
                android:layout_width="42dp"
                android:layout_height="65dp"
                android:layout_margin="4dp"
                android:background="@drawable/border_highlight"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:padding="0dp"
                android:textColor="#476568"
                android:textSize="26sp" />

        </LinearLayout>

        <!-- Botó de verificar -->
        <Button
            android:id="@+id/btnVerify"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="VERIFICAR"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/btn_circular_green"
            android:enabled="false"
            android:alpha="0.6"
            android:layout_marginBottom="16dp" />

        <!-- ProgressBar -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />

        <!-- Missatge d'error -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#FF0000"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />

        <!-- Reenviar codi -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <Button
                android:id="@+id/btnResend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reenviar codi"
                android:textSize="14sp"
                android:textColor="#8BC6CC"
                android:background="@null"
                android:enabled="false" />

            <TextView
                android:id="@+id/tvTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reenviar codi en 60 s"
                android:textSize="12sp"
                android:textColor="#999999" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>